# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for Edge Functions / server-only
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Go High Level
# GHL_API_TOKEN=your-ghl-pit-token
# GHL_LOCATION_ID=your-location-id

# Anthropic Claude API — LEGACY, kept only as a reference in
# `lib/anthropic/client.ts`. The active QA analyzer is GPT-4o via
# `lib/openai/client.ts`, so this key is no longer required.
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (REQUIRED for QA analysis) ─────────────────────────────────
# Used by `lib/openai/client.ts` for:
#   1. QA analysis with GPT-4o (5-pillar scoring, 1-10 per pillar). This
#      is the main, non-optional use — the pipeline cannot analyze calls
#      without this key.
#   2. Whisper transcription (legacy fallback only, behind Deepgram).
# OPENAI_API_KEY=sk-proj-...

# ── Transcription providers (cascade fallback) ────────────────────────
# Pipeline order: GHL built-in → Deepgram → OpenAI Whisper.
# At least one of Deepgram / OpenAI should be set (GHL's built-in
# transcription is often empty on MCA call recordings).

# Deepgram Nova-3 (preferred: no 25MB limit, auto-detects Spanish/English,
# cheaper, faster). Get a key at https://console.deepgram.com/
# DEEPGRAM_API_KEY=

# Pipeline internal secret (change in production)
# PIPELINE_SECRET=hd-pipeline-secret-local-dev

# ── Supabase Management API (for local DB migrations) ───────────────
# Optional. Lets `scripts/apply-migration.mjs` and `scripts/db-query.mjs`
# execute SQL against the project without going through the Supabase
# SQL Editor (the REST API can't run DDL).
#
# Generate the PAT at https://supabase.com/dashboard/account/tokens.
# It's workspace-level — scope it narrowly and revoke when done.
# The project ref is the subdomain of your SUPABASE_URL.
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=ouszjnrkawvrwxjjgrxx
